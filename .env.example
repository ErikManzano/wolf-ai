# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Tras crear la BD en Neon: npm run db:setup  (tablas Exercise OS + 37 ejercicios de exercises.json)
# Verificar: GET /health → exerciseCatalog.officialDefinitions ≈ 39

# --- JWT (obligatorio en producción: NODE_ENV=production) ---
# Secreto HMAC para firmar tokens; mínimo 32 caracteres. Generar: openssl rand -base64 48
# JWT_SECRET=
# Duración del access token (jose): 15m, 12h, 7d, etc.
# JWT_EXPIRES_IN=7d

