# Frontend: base del API (vacío = solo datos locales).
#
# --- Netlify (recomendado): proxy /api → Render (el build ejecuta prep-netlify-proxy.mjs) ---
#   NETLIFY_API_PROXY_TARGET=https://TU-SERVICIO.onrender.com
#   VITE_API_URL=/api
# Desarrollo con proxy: mismo VITE_API_URL=/api + npm run dev + npm run server (Vite reenvía /api → :4000)
# WebSocket tiempo real: ws(s)://localhost:5173/api/ws (proxy ws en vite.config).
# Si el WS falla en prod con proxy /api (Netlify), usa URL directa del API:
# VITE_WS_URL=wss://TU-API.onrender.com/ws
#
# --- O URL directa del API (hay que acertar CORS en Render: FRONTEND_ORIGIN) ---
# VITE_API_URL=https://TU-SERVICIO.onrender.com
#
# Local sin proxy:
# VITE_API_URL=http://localhost:4000

# API: origen del cliente (CORS). Debe coincidir EXACTO con la URL del front (https, sin barra final).
# FRONTEND_ORIGIN=http://localhost:5173
# Varios orígenes (prod + preview Netlify, www / sin www): lista separada por comas
# FRONTEND_ORIGINS=https://tu-app.netlify.app,https://deploy-preview-123--tu-app.netlify.app

# Postgres: al arrancar, reescribe contraseñas de los emails del seed con users.json (útil si la BD tenía hashes viejos).
# Pon 0 en producción tras provisionar cuentas reales (npm run db:provision-users).
# WOLF_SYNC_SEED_PASSWORDS=1

# API: deshabilitar registro público (Render / producción).
# WOLF_ALLOW_PUBLIC_REGISTER=0

# Frontend (Netlify build): ocultar registro y accesos demo en producción.
# VITE_ALLOW_PUBLIC_REGISTER=0
# VITE_SHOW_DEMO_LOGIN=0

