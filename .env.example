# Frontend: URL del API (vacío = solo datos locales importados desde src/data)
# VITE_API_URL=http://localhost:4000

# API: origen del cliente (CORS). Debe coincidir EXACTO con la URL del front (https, sin barra final).
# FRONTEND_ORIGIN=http://localhost:5173
# Varios orígenes (prod + preview Netlify, www / sin www): lista separada por comas
# FRONTEND_ORIGINS=https://tu-app.netlify.app,https://deploy-preview-123--tu-app.netlify.app

# Postgres: al arrancar, reescribe contraseñas de los emails del seed con users.json (útil si la BD tenía hashes viejos).
# Pon 0 solo si no quieres que el deploy pise contraseñas de esas cuentas demo.
# WOLF_SYNC_SEED_PASSWORDS=1

# Postgres (API). Sin esto el servidor usa memoria + mismo users.json en memoria al arrancar.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- JWT (obligatorio en producción: NODE_ENV=production) ---
# Secreto HMAC para firmar tokens; mínimo 32 caracteres. Generar: openssl rand -base64 48
# JWT_SECRET=
# Duración del access token (jose): 15m, 12h, 7d, etc.
# JWT_EXPIRES_IN=7d

# --- Contraseñas iniciales del seed (solo desarrollo; rotar en producción) ---
# Propietario (owner@wolf-ai.local, super_admin): Zr8!mKp2QxV7nLw4Hb1
# Coach (ivan.hellequin@wolf-ai.local): Tc5#fRn9Ys3Jw6Ae0
# Atleta (erik.manzano@wolf-ai.local): Dm4@vHt8Ql2Zp7Ux1
#
# Tras login/registro el API devuelve `token` (JWT). El cliente lo guarda y envía Authorization: Bearer <jwt>.
# GET /auth/me valida el token. Solo super_admin puede POST/PATCH/DELETE /users.
# Cambiar contraseña no invalida JWTs antiguos hasta que expiren; acortar JWT_EXPIRES_IN o rotar JWT_SECRET para forzar re-login.
# Hashes en users.json:
#   npm run hash-password -- "NuevaClaveSegura"
